@PACKAGE_INIT@

# libumbreon links Embree 4 and oneTBB PUBLIC (a static lib defers their symbols
# to the final link), so a consumer must be able to find them too. They are
# required to be CONFIG-discoverable, matching how the install export was built.
include(CMakeFindDependencyMacro)
find_dependency(embree 4)
find_dependency(TBB)

include("${CMAKE_CURRENT_LIST_DIR}/umbreonTargets.cmake")

# umbreonTargets.cmake may additionally define umbreon::umbreon_oidn_worker
# (IMPORTED executable) -- present ONLY when the providing umbreon build had
# UMBREON_WITH_OIDN enabled. It is not a package component; consumers test
#   if(TARGET umbreon::umbreon_oidn_worker)
# and can stage it into their own layout, e.g.
#   install(PROGRAMS $<TARGET_FILE:umbreon::umbreon_oidn_worker> DESTINATION bin)

check_required_components(umbreon)
